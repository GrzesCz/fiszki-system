{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "status": {
      "default": "planowane",
      "type": "string",
      "enum": [
        "planowane",
        "w_trakcie",
        "zrobione"
      ]
    },
    "cards": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "cat": {
            "type": "string"
          },
          "catLabel": {
            "type": "string"
          },
          "q": {
            "type": "string"
          },
          "a": {
            "type": "string"
          }
        },
        "required": [
          "cat",
          "catLabel",
          "q",
          "a"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "cards"
  ]
}