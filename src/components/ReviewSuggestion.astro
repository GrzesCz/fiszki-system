---
import { getNotatki } from '../lib/read-content';

const notatki = await getNotatki();
const today   = new Date().toISOString().split('T')[0];

// Notatki z zaległą powtórką – dane zawsze live
const toReview = notatki.filter(
  n => n.data.next_review_date != null &&
       n.data.next_review_date !== '' &&
       n.data.next_review_date <= today
);

const suggestion = toReview.length > 0 ? toReview[0] : null;
---

{suggestion && (
  <div class="review-card mb-4">
    <div class="review-header">
      <span class="review-icon">💡</span>
      <span class="review-title">Krzywa Zapominania Ostrzega!</span>
    </div>
    
    <div class="review-body">
      <h3 class="review-topic">{suggestion.data.title}</h3>
      
      <p class="review-text">
        System wykrył, że Twoja wiedza z tego zakresu może powoli zanikać. Czas na powtórkę!
      </p>
      
      <div class="review-task">
        <strong>Zadanie Feynmana:</strong> Spróbuj na głos wytłumaczyć ten temat "jak 5-latkowi", a następnie naszkicuj mapę myśli z pamięci.
      </div>
      
      <div class="review-actions">
        <a href={`/kategoria/${suggestion.data.category ? suggestion.data.category.toLowerCase().replace(/\s+/g, '-') : ''}`} class="btn-review">
          Przejdź do materiału →
        </a>
      </div>
    </div>
  </div>
)}

<style>
  .mb-4 {
    margin-bottom: 2rem;
  }
  .review-card {
    background: var(--surface);
    border: 1px solid var(--yellow);
    border-radius: 12px;
    overflow: hidden;
    width: 100%;
    max-width: 760px;
    box-shadow: 0 4px 20px rgba(247, 212, 74, 0.1);
  }
  
  .review-header {
    background: rgba(247, 212, 74, 0.15);
    border-bottom: 1px solid rgba(247, 212, 74, 0.3);
    padding: 0.75rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .review-icon {
    font-size: 1.2rem;
  }
  
  .review-title {
    color: var(--yellow);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  
  .review-body {
    padding: 1.5rem;
  }
  
  .review-topic {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }
  
  .review-text {
    color: var(--text-dim);
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
    line-height: 1.5;
  }
  
  .review-task {
    background: rgba(124, 106, 247, 0.1);
    border-left: 4px solid var(--accent);
    padding: 1rem;
    border-radius: 4px 8px 8px 4px;
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  
  .review-task strong {
    color: var(--accent);
    display: block;
    margin-bottom: 0.25rem;
  }
  
  .review-actions {
    display: flex;
    justify-content: flex-end;
  }
  
  .btn-review {
    display: inline-block;
    padding: 0.6rem 1.4rem;
    border-radius: 8px;
    border: 1px solid var(--yellow);
    background: transparent;
    color: var(--yellow);
    font-family: 'Syne', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }
  
  .btn-review:hover {
    background: rgba(247, 212, 74, 0.1);
    transform: translateY(-2px);
  }
</style>