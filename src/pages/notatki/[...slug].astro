---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { getNotatki } from '../../lib/read-content';

const { slug } = Astro.params;
const cleanSlug = slug?.replace(/\.md$/, '');

// Dane live (review_count, next_review_date itp.)
const allNotatki = await getNotatki();
const liveEntry  = allNotatki.find(n => n.id.replace(/\.md$/, '') === cleanSlug);

if (!liveEntry) {
  return Astro.redirect('/');
}

// render() wymaga entry z Astro collection – użyj tylko do wyrenderowania treści Markdown
const allCollection = await getCollection('notatki');
const collectionEntry = allCollection.find(n => n.id.replace(/\.md$/, '') === cleanSlug);

if (!collectionEntry) {
  return Astro.redirect('/');
}

const { Content } = await render(collectionEntry);

const categorySlug = liveEntry.data.category
  ? liveEntry.data.category.toLowerCase().replace(/\s+/g, '-')
  : '';
---
<BaseLayout title={liveEntry.data.title} subtitle={`Kategoria: ${liveEntry.data.category || 'Ogólne'}`}>
  
  <div class="navigation-bar">
    {categorySlug && (
      <a href={`/kategoria/${categorySlug}`} class="btn-secondary btn-small">
        ← Wróć do kategorii
      </a>
    )}
    <button class="btn-secondary btn-small" id="btn-review-done" data-slug={slug} data-count={liveEntry.data.review_count || 0}>
      ✓ Oznacz jako powtórzone
    </button>
  </div>

  {liveEntry.data.mindmap && (
    <div class="mindmap-container">
      <h3>🗺️ Mapa Myśli</h3>
      <a href={`/maps/${liveEntry.data.mindmap}`} target="_blank" rel="noopener noreferrer" title="Kliknij, aby powiększyć">
        <img src={`/maps/${liveEntry.data.mindmap}`} alt={`Mapa myśli dla ${liveEntry.data.title}`} class="mindmap-image" />
      </a>
      <p class="mindmap-hint">Kliknij na obrazek, aby otworzyć go w pełnym rozmiarze.</p>
    </div>
  )}

  <article class="markdown-body">
    <Content />
  </article>
</BaseLayout>

<style>
  .navigation-bar {
    width: 100%;
    max-width: 760px;
    display: flex;
    justify-content: space-between;
    margin-bottom: 2rem;
  }
  
  .btn-small {
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
    text-decoration: none;
    display: inline-flex;
  }

  /* Stylizacja Markdown dopasowana do motywu fiszek */
  .markdown-body {
    width: 100%;
    max-width: 760px;
    color: var(--text);
    font-family: 'Syne', sans-serif;
    line-height: 1.7;
    font-size: 1.05rem;
    padding-bottom: 4rem;
  }

  /* Ukrywamy pierwszy nagłówek z markdowna, żeby nie dublował się z tytułem strony */
  .markdown-body > :global(h1:first-of-type) {
    display: none;
  }

  .markdown-body :global(h1), 
  .markdown-body :global(h2), 
  .markdown-body :global(h3), 
  .markdown-body :global(h4) {
    color: var(--text);
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .markdown-body :global(h1) { font-size: 2.2rem; background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .markdown-body :global(h2) { font-size: 1.8rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; }
  .markdown-body :global(h3) { font-size: 1.4rem; color: var(--accent3); }
  
  .markdown-body :global(p) { margin-bottom: 1.2rem; }
  .markdown-body :global(ul), .markdown-body :global(ol) { margin-bottom: 1.2rem; padding-left: 1.5rem; }
  .markdown-body :global(li) { margin-bottom: 0.5rem; }
  
  .markdown-body :global(strong), .markdown-body :global(b) { color: var(--accent3); font-weight: 600; }
  .markdown-body :global(em), .markdown-body :global(i) { color: var(--yellow); font-style: normal; font-weight: 600; }
  
  .markdown-body :global(blockquote) {
    border-left: 4px solid var(--accent);
    background: rgba(124, 106, 247, 0.05);
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    border-radius: 0 8px 8px 0;
    font-style: italic;
    color: var(--text-dim);
  }
  
  .markdown-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color 0.2s;
  }
  
  .markdown-body :global(a:hover) {
    color: var(--accent2);
  }

  /* Kod */
  .markdown-body :global(pre) {
    background: var(--code-bg) !important; /* Nadpisuje Shiki jeśli trzeba */
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.2rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .markdown-body :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85em;
    background: var(--code-bg);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    border: 1px solid var(--border);
    color: #e8e8f0;
  }

  .markdown-body :global(pre code) {
    background: transparent;
    padding: 0;
    border: none;
    font-size: 1em;
  }

  /* Tabele */
  .markdown-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.95rem;
  }
  
  .markdown-body :global(th), .markdown-body :global(td) {
    border: 1px solid var(--border);
    padding: 0.75rem 1rem;
    text-align: left;
  }
  
  .markdown-body :global(th) {
    background: var(--surface2);
    font-weight: 600;
    color: var(--accent3);
  }
  
  .markdown-body :global(tr:nth-child(even)) {
    background: rgba(255, 255, 255, 0.02);
  }

  /* Stylizacja Map Myśli */
  .mindmap-container {
    width: 100%;
    max-width: 760px;
    margin: 0 auto 3rem auto;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
  }
  
  .mindmap-container h3 {
    color: var(--accent);
    margin-top: 0;
    margin-bottom: 1rem;
    font-family: 'Syne', sans-serif;
  }
  
  .mindmap-image {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    border: 1px solid var(--border);
    transition: transform 0.2s, box-shadow 0.2s;
    cursor: zoom-in;
  }
  
  .mindmap-image:hover {
    transform: scale(1.02);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }
  
  .mindmap-hint {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-top: 0.5rem;
    margin-bottom: 0;
  }
</style>

<script>
  function apiNotatkiUrl(s) {
    return '/api/notatki/' + s.split('/').map(encodeURIComponent).join('/');
  }
  const btn = document.getElementById('btn-review-done');
  if (btn) {
    btn.addEventListener('click', async () => {
      const slug = btn.getAttribute('data-slug');
      const currentCount = parseInt(btn.getAttribute('data-count') || '0', 10);
      
      // Prosty algorytm spaced repetition: 1 dzień, 3 dni, 7 dni, 14 dni, 30 dni...
      const intervals = [1, 3, 7, 14, 30, 60, 90];
      const nextInterval = intervals[Math.min(currentCount, intervals.length - 1)];
      
      const nextDate = new Date();
      nextDate.setDate(nextDate.getDate() + nextInterval);
      const nextDateString = nextDate.toISOString().split('T')[0];
      
      btn.textContent = '⏳ Zapisywanie...';
      btn.style.opacity = '0.5';
      
      try {
        const res = await fetch(apiNotatkiUrl(slug), {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            next_review_date: nextDateString,
            review_count: currentCount + 1
          })
        });
        
        if (res.ok) {
          btn.textContent = `✅ Zaplanowano na ${nextDateString}`;
          btn.style.color = 'var(--green)';
          btn.style.borderColor = 'var(--green)';
          btn.style.opacity = '1';
        } else {
          btn.textContent = '❌ Błąd zapisu';
          btn.style.opacity = '1';
        }
      } catch (err) {
        console.error(err);
        btn.textContent = '❌ Błąd zapisu';
        btn.style.opacity = '1';
      }
    });
  }
</script>
