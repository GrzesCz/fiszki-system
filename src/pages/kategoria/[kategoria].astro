---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getMindmapsFromFrontmatter } from '../../lib/mindmaps-frontmatter';
import { getNotatki, getFiszki } from '../../lib/read-content';
import { renderNoteMarkdown } from '../../lib/render-note-markdown';
import { findNoteMdPath } from '../../lib/find-note-md';

const { kategoria } = Astro.params;
const notatki = await getNotatki();   // live – aktualne dane z plików
const fiszki  = await getFiszki();    // live – aktualne dane z plików

// Znajdź kategorię na podstawie sluga
const allCategories = [
  ...notatki.map(n => n.data.category).filter(Boolean),
  ...fiszki.map(f => f.data.category).filter(Boolean),
];
const categoryName = allCategories.find(
  cat => cat!.toLowerCase().replace(/\s+/g, '-') === kategoria
);

if (!categoryName) {
  return Astro.redirect('/');
}

// Główna notatka to ta, która NIE jest ukryta (hidden !== true)
const categoryNotes = notatki.filter(n => n.data.category === categoryName);
const mainNote = categoryNotes.find(n => !n.data.hidden);
const categoryFiszki = fiszki.filter(f => f.data.category === categoryName);

let contentHtml = '';
let mindmaps: { file: string; rotation?: number; zoom?: number }[] = [];
let noteSlug = '';
let backUrl = '';
let liveNextReviewDate: string | undefined;
let liveReviewCount = 0;
if (mainNote) {
  liveNextReviewDate = mainNote.data.next_review_date;
  liveReviewCount    = mainNote.data.review_count ?? 0;
  mindmaps           = getMindmapsFromFrontmatter(mainNote.data as Record<string, unknown>);
  noteSlug           = mainNote.id.replace(/\.md$/, '');
  backUrl            = '/kategoria/' + (categoryName || '').toLowerCase().replace(/\s+/g, '-');

  try {
    const absPath = await findNoteMdPath(noteSlug);
    if (absPath) {
      contentHtml = await renderNoteMarkdown(absPath);
    }
  } catch (e) {
    console.error('Błąd renderowania notatki:', e);
  }
}
---
<BaseLayout title={categoryName} subtitle="Centrum Dowodzenia Tematem">
  
  {!mainNote && (
    <div class="empty-state">
      <div class="empty-icon">📝</div>
      <p>Brak głównej notatki dla tej kategorii.</p>
      <p class="empty-hint">Dodaj notatkę w panelu i upewnij się, że nie ma flagi "hidden: true".</p>
      <a href="/admin/upload-notatka" class="btn-to-admin">Wgraj Notatkę →</a>
    </div>
  )}

  {mainNote && (() => {
    const today = new Date().toISOString().split('T')[0];
    const needsReview = !liveNextReviewDate || liveNextReviewDate <= today;

    return (
      <div class="main-note-container" id="mainLayout">
        
        {/* Pasek z przyciskiem powtórki */}
        <div class="review-bar">
          {needsReview ? (
            <button class="btn-review-done" id="btnReviewDone" data-slug={mainNote.id} data-count={liveReviewCount}>
              ✓ Oznacz jako powtórzone
            </button>
          ) : (
            <span class="review-scheduled">
              ✅ Powtórka zaplanowana na: <strong>{liveNextReviewDate}</strong>
            </span>
          )}
        </div>
      
      {/* Pasek narzędzi układu */}
      <div class="layout-controls">
        <div class="layout-tabs">
          <button class="layout-btn" id="btnLayoutLeft" title="Tylko notatki">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/><rect x="3" y="3" width="6" height="18" fill="currentColor" opacity="0.3"/></svg>
          </button>
          <button class="layout-btn active" id="btnLayoutSplit" title="Podział ekranu">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M12 3v18"/></svg>
          </button>
          <button class="layout-btn" id="btnLayoutRight" title="Tylko mapa">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M15 3v18"/><rect x="15" y="3" width="6" height="18" fill="currentColor" opacity="0.3"/></svg>
          </button>
        </div>
      </div>

      <div class="split-view">
        {/* 1. SEKCJA GŁÓWNEJ NOTATKI (LEWA) */}
        <div class="split-col" id="colNotes">
          <div class="category-section text-section">
            <h2 class="section-title">📖 Notatki</h2>
            <article class="markdown-body" set:html={contentHtml}></article>
          </div>
        </div>

        {/* 2. SEKCJA MAPY MYŚLI (PRAWA) */}
        <div class="split-col" id="colMap">
          <div class="category-section map-section">
            <div class="map-header">
              <h2 class="section-title">🗺️ Mapy Myśli</h2>
            </div>
            {mindmaps.length > 0 && (
              <div class="mindmaps-thumbnails" id="mindmapsThumbnails" data-mindmaps={JSON.stringify(mindmaps)} data-slug={noteSlug} title="Przeciągnij miniatury, aby zmienić kolejność. Kliknij, aby przewinąć do mapy.">
                {mindmaps.map((m, idx) => (
                  <div class="thumb-item" data-map-index={idx} draggable="true" title={`Mapa ${idx + 1} – przeciągnij lub kliknij`}>
                    <img src={`/maps/${m.file}`} alt="" draggable="false" style={`transform: rotate(${m.rotation ?? 0}deg)`} />
                    <span class="thumb-num">{idx + 1}</span>
                  </div>
                ))}
              </div>
            )}
            {mindmaps.length > 0 && (
              <div class="mindmaps-list" id="mindmapsList" data-mindmaps={JSON.stringify(mindmaps)} data-slug={noteSlug}>
                {mindmaps.map((m, idx) => (
                  <div class="map-card map-card-draggable" id={"map-card-" + idx} data-map-index={idx} draggable="true">
                    <div class="map-card-toolbar">
                      <span class="map-drag-handle" title="Przeciągnij, aby zmienić kolejność">⋮⋮</span>
                      <button class="btn-secondary btn-small map-rotate" data-slug={noteSlug} data-map-index={idx} data-rotation={m.rotation ?? 0} data-direction="-90" title="Obróć w lewo">↺ Obróć w lewo</button>
                      <button class="btn-secondary btn-small map-rotate" data-slug={noteSlug} data-map-index={idx} data-rotation={m.rotation ?? 0} data-direction="90" title="Obróć w prawo">↻ Obróć w prawo</button>
                      <button class="btn-secondary btn-small map-replace" data-map-index={idx}>🔄 Zmień</button>
                      <button class="btn-secondary btn-small btn-danger map-delete" data-slug={noteSlug} data-map-index={idx} title="Usuń mapę">🗑️ Usuń</button>
                    </div>
                    <div class="map-showcase">
                      <div class="mindmap-img-wrap" style={`transform: rotate(${m.rotation ?? 0}deg)`}>
                        <a href={`/viewer?file=${encodeURIComponent(m.file)}&rotation=${m.rotation ?? 0}&zoom=${m.zoom ?? 100}&back=${encodeURIComponent(backUrl)}`} target="_blank" rel="noopener noreferrer" title="Kliknij, aby otworzyć w pełnym rozmiarze">
                          <img src={`/maps/${m.file}`} alt={`Mapa myśli ${idx + 1} - ${categoryName}`} class="mindmap-image" draggable="false" />
                        </a>
                      </div>
                      <p class="mindmap-hint">Kliknij, aby otworzyć w pełnym rozmiarze</p>
                    </div>
                  </div>
                ))}
              </div>
            )}
            <div class="map-placeholder map-add-more" id="dropZoneAdd">
              <p>+ <strong>Dodaj kolejną mapę</strong> – upuść plik lub kliknij</p>
              <input type="file" id="mapFileInputAdd" style="display: none;" accept="image/png,image/jpeg,image/svg+xml,image/webp" />
              <button class="btn-secondary btn-small" onclick="document.getElementById('mapFileInputAdd').click()">
                Wybierz plik
              </button>
            </div>
            <form id="uploadMapForm" style="display: none;">
              <input type="hidden" name="noteSlug" value={noteSlug} />
              <input type="file" name="file" id="hiddenFileInput" />
            </form>
            <div id="uploadMsg" class="form-msg hidden"></div>
          </div>
        </div>
      </div>
      </div>
    );
  })()}

  {/* 3. SEKCJA FISZEK NA DOLE (PEŁNA SZEROKOŚĆ) */}
  {categoryFiszki.length > 0 && (
    <div class="fiszki-section-wrapper">
      <div class="category-section fiszki-section">
        <h2 class="section-title">🃏 Fiszki do przećwiczenia</h2>
        <div class="tiles-grid sub-tiles">
          {categoryFiszki.map((fiszka) => (
            <a href={`/tematy/${fiszka.id}`} class="tile-link">
              <h2>{fiszka.data.title}</h2>
              <p class="tile-subtitle">{fiszka.data.subtitle || 'Zestaw fiszek'}</p>
              <p class="tile-count">{fiszka.data.cards.length} fiszek</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  )}

</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    function apiNotatkiUrl(s) {
      return '/api/notatki/' + s.split('/').map(encodeURIComponent).join('/');
    }
    // --- PRZYCISK OZNACZ JAKO POWTÓRZONE ---
    const btnReview = document.getElementById('btnReviewDone');
    if (btnReview) {
      btnReview.addEventListener('click', async () => {
        const slug = btnReview.getAttribute('data-slug');
        const currentCount = parseInt(btnReview.getAttribute('data-count') || '0', 10);
        
        const intervals = [1, 3, 7, 14, 30, 60, 90];
        const nextInterval = intervals[Math.min(currentCount, intervals.length - 1)];
        
        const nextDate = new Date();
        nextDate.setDate(nextDate.getDate() + nextInterval);
        const nextDateString = nextDate.toISOString().split('T')[0];
        
        btnReview.textContent = '⏳ Zapisywanie...';
        btnReview.style.opacity = '0.5';
        
        try {
          const res = await fetch(apiNotatkiUrl(slug), {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              next_review_date: nextDateString,
              review_count: currentCount + 1
            })
          });
          
          if (res.ok) {
            btnReview.outerHTML = `<span class="review-scheduled">✅ Powtórka zaplanowana na: <strong>${nextDateString}</strong></span>`;
          } else {
            btnReview.textContent = '❌ Błąd zapisu';
            btnReview.style.opacity = '1';
          }
        } catch (err) {
          console.error(err);
          btnReview.textContent = '❌ Błąd zapisu';
          btnReview.style.opacity = '1';
        }
      });
    }

    // --- LAYOUT TOGGLES ---
    const layoutWrapper = document.getElementById('mainLayout');
    const colNotes = document.getElementById('colNotes');
    const colMap = document.getElementById('colMap');
    
    const btnLeft = document.getElementById('btnLayoutLeft');
    const btnSplit = document.getElementById('btnLayoutSplit');
    const btnRight = document.getElementById('btnLayoutRight');

    // Odczytaj preferencję
    const savedLayout = localStorage.getItem('fiszki_layout') || 'split';
    
    function setLayout(mode) {
      if (!layoutWrapper) return;
      
      // Reset
      [btnLeft, btnSplit, btnRight].forEach(b => b.classList.remove('active'));
      colNotes.style.display = '';
      colMap.style.display = '';
      layoutWrapper.className = 'main-note-container';

      if (mode === 'left') {
        btnLeft.classList.add('active');
        colMap.style.display = 'none';
        layoutWrapper.classList.add('layout-single');
      } else if (mode === 'right') {
        btnRight.classList.add('active');
        colNotes.style.display = 'none';
        layoutWrapper.classList.add('layout-single');
      } else {
        btnSplit.classList.add('active');
        // split to domyślny css
      }
      
      localStorage.setItem('fiszki_layout', mode);
    }

    setLayout(savedLayout);

    btnLeft?.addEventListener('click', () => setLayout('left'));
    btnSplit?.addEventListener('click', () => setLayout('split'));
    btnRight?.addEventListener('click', () => setLayout('right'));


    // --- DRAG & DROP UPLOAD MAPY ---
    const dropZone = document.getElementById('dropZone');
    const hiddenInput = document.getElementById('hiddenFileInput');
    const visibleInput = document.getElementById('mapFileInput');
    const uploadForm = document.getElementById('uploadMapForm');
    const uploadMsg = document.getElementById('uploadMsg');

    async function handleUpload(file) {
      if (!file) return;
      
      const dataTransfer = new DataTransfer();
      dataTransfer.items.add(file);
      hiddenInput.files = dataTransfer.files;

      uploadMsg.className = 'form-msg';
      uploadMsg.textContent = 'Wgrywanie mapy...';
      
      const formData = new FormData(uploadForm);
      try {
        const res = await fetch('/api/upload-map', { method: 'POST', body: formData });
        const json = await res.json();
        if (res.ok) {
          uploadMsg.className = 'form-msg success';
          uploadMsg.textContent = 'Wgrano pomyślnie! Odświeżanie...';
          setTimeout(() => location.reload(), 800);
        } else {
          uploadMsg.className = 'form-msg error';
          uploadMsg.textContent = `Błąd: ${json.error}`;
        }
      } catch (err) {
        uploadMsg.className = 'form-msg error';
        uploadMsg.textContent = 'Wystąpił błąd podczas wgrywania.';
      }
    }

    if (dropZone) {
      ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
        dropZone.addEventListener(eventName, preventDefaults, false);
      });

      function preventDefaults(e) { e.preventDefault(); e.stopPropagation(); }

      ['dragenter', 'dragover'].forEach(eventName => {
        dropZone.addEventListener(eventName, () => dropZone.classList.add('drag-active'), false);
      });

      ['dragleave', 'drop'].forEach(eventName => {
        dropZone.addEventListener(eventName, () => dropZone.classList.remove('drag-active'), false);
      });

      dropZone.addEventListener('drop', (e) => {
        const file = e.dataTransfer.files[0];
        handleUpload(file);
      });
    }

    if (visibleInput) {
      visibleInput.addEventListener('change', (e) => {
        handleUpload(e.target.files[0]);
      });
    }
    
    // --- DROP ZONE "DODAJ KOLEJNĄ" ---
    const dropZoneAdd = document.getElementById('dropZoneAdd');
    const mapFileInputAdd = document.getElementById('mapFileInputAdd');
    if (dropZoneAdd) {
      ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(ev => dropZoneAdd.addEventListener(ev, (e) => { e.preventDefault(); e.stopPropagation(); }));
      ['dragenter', 'dragover'].forEach(ev => dropZoneAdd.addEventListener(ev, () => dropZoneAdd.classList.add('drag-active')));
      ['dragleave', 'drop'].forEach(ev => dropZoneAdd.addEventListener(ev, () => dropZoneAdd.classList.remove('drag-active')));
      dropZoneAdd.addEventListener('drop', (e) => handleUpload(e.dataTransfer?.files?.[0]));
      dropZoneAdd.addEventListener('click', (e) => {
        if (e.target.tagName !== 'BUTTON' && e.target.tagName !== 'INPUT') {
           mapFileInputAdd?.click();
        }
      });
    }
    if (mapFileInputAdd) {
      mapFileInputAdd.addEventListener('change', (e) => handleUpload(e.target.files[0]));
    }

    // --- ZMIANA MAPY (Zmień) – event delegation ---
    document.addEventListener('click', (e) => {
      const replaceBtn = e.target.closest('.map-replace');
      if (replaceBtn && uploadForm) {
        const mapIndex = replaceBtn.getAttribute('data-map-index');
        const tempInput = document.createElement('input');
        tempInput.type = 'file';
        tempInput.accept = 'image/png,image/jpeg,image/svg+xml,image/webp';
        tempInput.onchange = async (ev) => {
          const file = ev.target.files[0];
          if (!file) return;
          const formData = new FormData(uploadForm);
          formData.set('file', file);
          if (mapIndex !== null) formData.set('replaceMapIndex', mapIndex);
          uploadMsg.className = 'form-msg';
          uploadMsg.textContent = 'Wgrywanie...';
          try {
            const res = await fetch('/api/upload-map', { method: 'POST', body: formData });
            const json = await res.json();
            if (res.ok) {
              uploadMsg.className = 'form-msg success';
              uploadMsg.textContent = 'Wgrano! Odświeżanie...';
              setTimeout(() => location.reload(), 600);
            } else {
              uploadMsg.className = 'form-msg error';
              uploadMsg.textContent = json.error || 'Błąd';
            }
          } catch {
            uploadMsg.className = 'form-msg error';
            uploadMsg.textContent = 'Błąd wgrywania.';
          }
        };
        tempInput.click();
      }
    });

    // --- OBRÓT MAPY (event delegation) – bez przeładowania, aktualizacja DOM ---
    document.addEventListener('click', async (e) => {
      const rotateBtn = e.target.closest('.map-rotate');
      if (!rotateBtn) return;
      const card = rotateBtn.closest('.map-card');
      const slug = rotateBtn.getAttribute('data-slug');
      const idx = rotateBtn.getAttribute('data-map-index');
      const current = parseInt(rotateBtn.getAttribute('data-rotation') || '0', 10);
      const direction = parseInt(rotateBtn.getAttribute('data-direction') || '90', 10);
      const next = ((current + direction) % 360 + 360) % 360;
      const origText = rotateBtn.textContent;
      rotateBtn.textContent = '⏳...';
      try {
        const res = await fetch(apiNotatkiUrl(slug), {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ mindmap_index: parseInt(idx || '0', 10), mindmap_rotation: next })
        });
        if (res.ok) {
          card.querySelectorAll('.map-rotate').forEach(btn => btn.setAttribute('data-rotation', String(next)));
          const wrap = card.querySelector('.mindmap-img-wrap');
          if (wrap) wrap.style.transform = 'rotate(' + next + 'deg)';
          const link = card.querySelector('a[href*="/viewer"]');
          if (link) {
            const url = new URL(link.href);
            url.searchParams.set('rotation', String(next));
            link.href = url.toString();
          }
          const list = document.getElementById('mindmapsList');
          const thumbs = document.getElementById('mindmapsThumbnails');
          if (list) {
            try {
              const maps = JSON.parse(list.getAttribute('data-mindmaps') || '[]');
              if (maps[parseInt(idx || '0', 10)]) {
                maps[parseInt(idx || '0', 10)].rotation = next;
                const newStr = JSON.stringify(maps);
                list.setAttribute('data-mindmaps', newStr);
                if (thumbs) {
                  thumbs.setAttribute('data-mindmaps', newStr);
                  const thumbImg = thumbs.querySelector(`[data-map-index="${idx}"] img`);
                  if (thumbImg) thumbImg.style.transform = 'rotate(' + next + 'deg)';
                }
              }
            } catch {}
          }
        }
        rotateBtn.textContent = origText;
      } catch {
        rotateBtn.textContent = origText;
      }
    });

    // --- USUWANIE MAPY (event delegation) ---
    document.addEventListener('click', async (e) => {
      const deleteBtn = e.target.closest('.map-delete');
      if (!deleteBtn) return;
      if (!confirm('Czy na pewno chcesz usunąć tę mapę? Plik zostanie trwale usunięty.')) return;
      const slug = deleteBtn.getAttribute('data-slug');
      const mapIndex = parseInt(deleteBtn.getAttribute('data-map-index') || '0', 10);
      deleteBtn.textContent = '⏳...';
      deleteBtn.disabled = true;
      try {
        const res = await fetch('/api/delete-map', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ noteSlug: slug, mapIndex })
        });
        if (res.ok) {
          sessionStorage.setItem('mindmapsScrollTo', String(Math.max(0, mapIndex - 1)));
          location.reload();
        } else {
          deleteBtn.textContent = '🗑️ Usuń';
          deleteBtn.disabled = false;
        }
      } catch {
        deleteBtn.textContent = '🗑️ Usuń';
        deleteBtn.disabled = false;
      }
    });

    // --- MINIATURY – klik przewija do mapy, drag zmienia kolejność ---
    const thumbnails = document.getElementById('mindmapsThumbnails');
    if (thumbnails) {
      let justDragged = false;
      thumbnails.querySelectorAll('.thumb-item').forEach((thumb, i) => {
        thumb.addEventListener('click', (e) => {
          if (justDragged) return;
          const card = document.getElementById('map-card-' + i);
          if (card) card.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
      });
      let thumbDraggedIdx = null;
      thumbnails.addEventListener('dragstart', (e) => {
        const item = e.target.closest('.thumb-item');
        if (!item) return;
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', item.getAttribute('data-map-index') || '0');
        item.classList.add('dragging');
        thumbDraggedIdx = parseInt(item.getAttribute('data-map-index') || '0', 10);
      });
      thumbnails.addEventListener('dragend', (e) => {
        thumbnails.querySelectorAll('.thumb-item').forEach(t => t.classList.remove('dragging', 'drag-over'));
        thumbDraggedIdx = null;
      });
      thumbnails.addEventListener('dragover', (e) => {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        const item = e.target.closest('.thumb-item');
        if (item && thumbDraggedIdx !== null) {
          thumbnails.querySelectorAll('.thumb-item').forEach(t => t.classList.remove('drag-over'));
          item.classList.add('drag-over');
        }
      });
      thumbnails.addEventListener('dragleave', (e) => {
        if (!thumbnails.contains(e.relatedTarget)) {
          thumbnails.querySelectorAll('.thumb-item').forEach(t => t.classList.remove('drag-over'));
        }
      });
      thumbnails.addEventListener('drop', async (e) => {
        e.preventDefault();
        justDragged = true;
        setTimeout(() => { justDragged = false; }, 100);
        const item = e.target.closest('.thumb-item');
        if (!item) return;
        const fromIdx = parseInt(e.dataTransfer.getData('text/plain') || '0', 10);
        const toIdx = parseInt(item.getAttribute('data-map-index') || '0', 10);
        if (fromIdx === toIdx) return;
        const dataStr = thumbnails.getAttribute('data-mindmaps');
        const slug = thumbnails.getAttribute('data-slug');
        if (!dataStr || !slug) return;
        let maps;
        try {
          maps = JSON.parse(dataStr);
        } catch { return; }
        const [moved] = maps.splice(fromIdx, 1);
        maps.splice(toIdx, 0, moved);
        thumbnails.querySelectorAll('.thumb-item').forEach(t => t.classList.remove('drag-over'));
        try {
          const res = await fetch(apiNotatkiUrl(slug), {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ mindmaps: maps })
          });
          if (res.ok) {
            sessionStorage.setItem('mindmapsScrollTo', String(Math.min(toIdx, maps.length - 1)));
            location.reload();
          }
        } catch {}
      });
    }

    // --- PRZESTAWIANIE KOLEJNOŚCI MAP (drag & drop na kartach) ---
    const mindmapsList = document.getElementById('mindmapsList');
    if (mindmapsList && mindmapsList.querySelectorAll('.map-card-draggable').length > 1) {
      let draggedIdx = null;
      mindmapsList.addEventListener('dragstart', (e) => {
        const card = e.target.closest('.map-card-draggable');
        if (!card) return;
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', card.getAttribute('data-map-index') || '0');
        e.dataTransfer.setData('application/json', JSON.stringify({ index: parseInt(card.getAttribute('data-map-index') || '0', 10) }));
        card.classList.add('dragging');
        draggedIdx = parseInt(card.getAttribute('data-map-index') || '0', 10);
      });
      mindmapsList.addEventListener('dragend', (e) => {
        const card = e.target.closest('.map-card-draggable');
        if (card) card.classList.remove('dragging');
        mindmapsList.querySelectorAll('.map-card-draggable').forEach(c => c.classList.remove('drag-over'));
        draggedIdx = null;
      });
      mindmapsList.addEventListener('dragover', (e) => {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        const card = e.target.closest('.map-card-draggable');
        if (card && draggedIdx !== null) {
          mindmapsList.querySelectorAll('.map-card-draggable').forEach(c => c.classList.remove('drag-over'));
          card.classList.add('drag-over');
        }
      });
      mindmapsList.addEventListener('dragleave', (e) => {
        if (!mindmapsList.contains(e.relatedTarget)) {
          mindmapsList.querySelectorAll('.map-card-draggable').forEach(c => c.classList.remove('drag-over'));
        }
      });
      mindmapsList.addEventListener('drop', async (e) => {
        e.preventDefault();
        const card = e.target.closest('.map-card-draggable');
        if (!card) return;
        const fromIdx = parseInt(e.dataTransfer.getData('text/plain') || '0', 10);
        const toIdx = parseInt(card.getAttribute('data-map-index') || '0', 10);
        if (fromIdx === toIdx) return;
        const dataStr = mindmapsList.getAttribute('data-mindmaps');
        const slug = mindmapsList.getAttribute('data-slug');
        if (!dataStr || !slug) return;
        let maps;
        try {
          maps = JSON.parse(dataStr);
        } catch {
          return;
        }
        const [moved] = maps.splice(fromIdx, 1);
        maps.splice(toIdx, 0, moved);
        mindmapsList.querySelectorAll('.map-card-draggable').forEach(c => c.classList.remove('drag-over'));
        try {
          const res = await fetch(apiNotatkiUrl(slug), {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ mindmaps: maps })
          });
          if (res.ok) {
            sessionStorage.setItem('mindmapsScrollTo', String(Math.min(toIdx, maps.length - 1)));
            location.reload();
          }
        } catch {}
      });
    }

    // --- Przewijanie do mapy po przeładowaniu (delete/reorder) ---
    const scrollTo = sessionStorage.getItem('mindmapsScrollTo');
    if (scrollTo !== null) {
      sessionStorage.removeItem('mindmapsScrollTo');
      requestAnimationFrame(() => {
        const el = document.getElementById('map-card-' + scrollTo);
        if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });
    }
  });
</script>

