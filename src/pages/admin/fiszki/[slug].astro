---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getFiszki } from '../../../lib/read-content';

const { slug } = Astro.params;
const fiszki = await getFiszki();
const entry = fiszki.find(f => f.id === slug);

// Może być nowy temat bez fiszek – wtedy tworzymy pustą strukturę
const title = entry?.data.title || slug;
const cards = entry?.data.cards || [];
const category = entry?.data.category || '';
---
<BaseLayout title={`Fiszki: ${title}`} subtitle="Edytowanie zestawu fiszek">

  <div class="admin-nav">
    <a href="/admin" class="btn-secondary btn-small">← Panel zarządzania</a>
    {entry && <a href={`/tematy/${slug}`} class="btn-secondary btn-small">👁 Podgląd fiszek</a>}
  </div>

  <div class="cards-editor" id="cardsEditor">
    <div class="editor-header">
      <h3 class="section-label">🃏 Karty w zestawie</h3>
      <button id="addCard" class="btn-primary btn-small">+ Dodaj kartę</button>
    </div>

    <div id="cardsList">
      {cards.map((card, i) => (
        <div class="card-edit-item" data-index={i}>
          <div class="card-edit-header">
            <span class="card-num">#{i + 1}</span>
            <select class="cat-select" name={`cat-${i}`}>
              <option value="pojecie" selected={card.cat === 'pojecie'}>💡 Pojęcie</option>
              <option value="kod" selected={card.cat === 'kod'}>💻 Kod</option>
              <option value="analogia" selected={card.cat === 'analogia'}>🔗 Analogia</option>
              <option value="naming" selected={card.cat === 'naming'}>🏷 Naming</option>
            </select>
            <button class="btn-icon btn-delete-card" title="Usuń kartę">🗑</button>
          </div>
          <div class="card-edit-fields">
            <textarea class="card-q" name={`q-${i}`} placeholder="Pytanie..." rows="2">{card.q}</textarea>
            <textarea class="card-a" name={`a-${i}`} placeholder="Odpowiedź..." rows="3">{card.a}</textarea>
          </div>
        </div>
      ))}
    </div>

    <div id="saveMsg" class="form-msg hidden"></div>

    <div class="form-actions">
      <button id="saveCards" class="btn-primary">Zapisz wszystkie fiszki</button>
    </div>
  </div>

</BaseLayout>

<script is:inline define:vars={{ slug, title, category, initialCards: cards }}>
  const catLabels = { pojecie: '💡 Pojęcie', kod: '💻 Kod', analogia: '🔗 Analogia', naming: '🏷 Naming' };

  function createCardItem(index, card = { cat: 'pojecie', q: '', a: '' }) {
    const div = document.createElement('div');
    div.className = 'card-edit-item';
    div.dataset.index = index;
    div.innerHTML = `
      <div class="card-edit-header">
        <span class="card-num">#${index + 1}</span>
        <select class="cat-select" name="cat-${index}">
          <option value="pojecie" ${card.cat === 'pojecie' ? 'selected' : ''}>💡 Pojęcie</option>
          <option value="kod" ${card.cat === 'kod' ? 'selected' : ''}>💻 Kod</option>
          <option value="analogia" ${card.cat === 'analogia' ? 'selected' : ''}>🔗 Analogia</option>
          <option value="naming" ${card.cat === 'naming' ? 'selected' : ''}>🏷 Naming</option>
        </select>
        <button class="btn-icon btn-delete-card" title="Usuń kartę">🗑</button>
      </div>
      <div class="card-edit-fields">
        <textarea class="card-q" name="q-${index}" placeholder="Pytanie..." rows="2">${card.q}</textarea>
        <textarea class="card-a" name="a-${index}" placeholder="Odpowiedź..." rows="3">${card.a}</textarea>
      </div>
    `;
    div.querySelector('.btn-delete-card').addEventListener('click', () => div.remove());
    return div;
  }

  // Dodaj obsługę usuń do istniejących kart
  document.querySelectorAll('.btn-delete-card').forEach(btn => {
    btn.addEventListener('click', () => btn.closest('.card-edit-item').remove());
  });

  // Dodaj nową kartę
  document.getElementById('addCard').addEventListener('click', () => {
    const list = document.getElementById('cardsList');
    const count = list.querySelectorAll('.card-edit-item').length;
    const item = createCardItem(count);
    list.appendChild(item);
    item.scrollIntoView({ behavior: 'smooth' });
  });

  // Zapisz wszystkie
  document.getElementById('saveCards').addEventListener('click', async () => {
    const items = document.querySelectorAll('.card-edit-item');
    const cards = Array.from(items).map(item => {
      const cat = item.querySelector('.cat-select').value;
      return {
        cat,
        catLabel: catLabels[cat],
        q: item.querySelector('.card-q').value.trim(),
        a: item.querySelector('.card-a').value.trim(),
      };
    }).filter(c => c.q && c.a);

    const msg = document.getElementById('saveMsg');
    msg.className = 'form-msg';
    msg.textContent = 'Zapisywanie...';

    const res = await fetch(`/api/fiszki/${slug}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title, category, cards }),
    });

    const json = await res.json();
    if (res.ok) {
      msg.className = 'form-msg success';
      msg.textContent = `✓ Zapisano ${cards.length} fiszek!`;
    } else {
      msg.className = 'form-msg error';
      msg.textContent = `Błąd: ${json.error}`;
    }
  });
</script>

<style>
  .admin-nav {
    width: 100%;
    max-width: 760px;
    display: flex;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  .btn-small {
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }
  .cards-editor {
    width: 100%;
    max-width: 760px;
  }
  .editor-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }
  .section-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  #cardsList {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .card-edit-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem 1.25rem;
  }
  .card-edit-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .card-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--text-dim);
    min-width: 2rem;
  }
  .cat-select {
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-size: 0.8rem;
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
    cursor: pointer;
  }
  .btn-icon {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.9rem;
    padding: 0.25rem;
    border-radius: 6px;
    transition: background 0.15s;
    margin-left: auto;
  }
  .btn-icon:hover { background: var(--surface2); }
  .btn-delete-card {
    color: var(--red);
  }
  .btn-delete-card:hover {
    background: rgba(247,74,106,0.2);
    color: var(--red);
  }
  .card-edit-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  .card-q, .card-a {
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-size: 0.9rem;
    padding: 0.6rem 0.8rem;
    border-radius: 8px;
    resize: vertical;
    outline: none;
    transition: border-color 0.2s;
  }
  .card-q:focus, .card-a:focus { border-color: var(--accent); }
  .form-actions { margin-top: 1rem; }
  .btn-primary {
    padding: 0.75rem 1.5rem;
    border-radius: 10px;
    border: 1px solid var(--accent);
    background: rgba(124,106,247,0.12);
    color: var(--accent);
    font-family: 'Syne', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-primary:hover { background: rgba(124,106,247,0.25); }
  .form-msg { padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.9rem; margin-top: 0.75rem; }
  .form-msg.hidden { display: none; }
  .form-msg.success { background: rgba(74,247,154,0.1); color: var(--green); border: 1px solid var(--green); }
  .form-msg.error { background: rgba(247,74,106,0.1); color: var(--red); border: 1px solid var(--red); }
  @media (max-width: 600px) {
    .card-edit-fields { grid-template-columns: 1fr; }
  }
</style>
