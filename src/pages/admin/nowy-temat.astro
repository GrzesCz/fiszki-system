---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const notatki = await getCollection('notatki');
const fiszki = await getCollection('fiszki');

const allCategories = Array.from(new Set([
  ...notatki.map(n => n.data.category).filter(Boolean),
  ...fiszki.map(f => f.data.category).filter(Boolean),
])).sort() as string[];
---
<BaseLayout title="Nowy Temat" subtitle="Dodaj nową grupę fiszek">

  <div class="admin-nav">
    <a href="/admin" class="btn-secondary btn-small">← Panel zarządzania</a>
  </div>

  <form id="newTopicForm" class="admin-form">
    <div class="form-group">
      <label for="title">Tytuł tematu *</label>
      <input type="text" id="title" name="title" required placeholder="np. Python – Dekoratory" />
    </div>

    <div class="form-group">
      <label for="category">Kategoria *</label>
      <div class="input-with-hint">
        <input type="text" id="category" name="category" required placeholder="np. Python"
               list="categoryList" />
        <datalist id="categoryList">
          {allCategories.map(cat => <option value={cat} />)}
        </datalist>
      </div>
      <p class="hint">Wybierz istniejącą lub wpisz nową kategorię</p>
    </div>

    <div class="form-group">
      <label for="status">Status</label>
      <select id="status" name="status">
        <option value="planowane">○ Planowane</option>
        <option value="w_trakcie">⟳ W trakcie</option>
        <option value="zrobione">✓ Zrobione</option>
      </select>
    </div>

    <div id="formMsg" class="form-msg hidden"></div>

    <div class="form-actions">
      <button type="submit" class="btn-primary">Utwórz temat</button>
      <a href="/admin" class="btn-secondary">Anuluj</a>
    </div>
  </form>

</BaseLayout>

<script is:inline>
  document.getElementById('newTopicForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const data = {
      title: form.title.value.trim(),
      category: form.category.value.trim(),
      status: form.status.value,
    };

    const msg = document.getElementById('formMsg');
    msg.className = 'form-msg';
    msg.textContent = 'Tworzenie...';

    const res = await fetch('/api/tematy', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });

    const json = await res.json();
    if (res.ok) {
      msg.className = 'form-msg success';
      msg.textContent = `✓ Temat "${data.title}" utworzony! Możesz teraz dodać do niego fiszki.`;
      form.reset();
      setTimeout(() => window.location.href = `/admin/fiszki/${json.slug}`, 1200);
    } else {
      msg.className = 'form-msg error';
      msg.textContent = `Błąd: ${json.error}`;
    }
  });
</script>

<style>
  .admin-nav {
    width: 100%;
    max-width: 760px;
    margin-bottom: 2rem;
  }
  .btn-small {
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
    text-decoration: none;
    display: inline-flex;
  }
  .admin-form {
    width: 100%;
    max-width: 560px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  label {
    font-size: 0.8rem;
    font-family: 'JetBrains Mono', monospace;
    color: var(--text-dim);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  input, select {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    padding: 0.7rem 1rem;
    border-radius: 10px;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }
  input:focus, select:focus { border-color: var(--accent); }
  .hint {
    font-size: 0.75rem;
    color: var(--text-dim);
    margin-top: 0.1rem;
  }
  .form-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-top: 0.5rem;
  }
  .btn-primary {
    padding: 0.75rem 1.5rem;
    border-radius: 10px;
    border: 1px solid var(--accent);
    background: rgba(124,106,247,0.12);
    color: var(--accent);
    font-family: 'Syne', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-primary:hover { background: rgba(124,106,247,0.25); }
  .form-msg {
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
  }
  .form-msg.hidden { display: none; }
  .form-msg.success { background: rgba(74,247,154,0.1); color: var(--green); border: 1px solid var(--green); }
  .form-msg.error { background: rgba(247,74,106,0.1); color: var(--red); border: 1px solid var(--red); }
</style>
