---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const slugParam = Astro.params.slug ?? '';
const cleanSlug = slugParam.replace(/\.md$/, '');
const notatki = await getCollection('notatki');
const entry = notatki.find(n => n.id.replace(/\.md$/, '') === cleanSlug);
const slug = cleanSlug;

if (!entry) {
  return Astro.redirect('/admin');
}
---
<BaseLayout title={`Mapa Myśli: ${entry.data.title}`} subtitle="Zarządzanie mapą myśli">

  <div class="admin-nav">
    <a href="/admin" class="btn-secondary btn-small">← Panel zarządzania</a>
    <a href={`/notatki/${slug}`} class="btn-secondary btn-small">👁 Podgląd notatki</a>
  </div>

  <!-- Aktualnie przypisana mapa -->
  {entry.data.mindmap ? (
    <div class="current-map">
      <h3 class="section-label">🗺️ Aktualna mapa myśli</h3>
      <div class="map-preview">
        <img src={`/maps/${entry.data.mindmap}`} alt="Aktualna mapa myśli" class="map-img" />
        <p class="map-filename">{entry.data.mindmap}</p>
      </div>
    </div>
  ) : (
    <div class="no-map">
      <p>Brak przypisanej mapy myśli.</p>
    </div>
  )}

  <!-- Upload nowego skanu -->
  <div class="admin-section">
    <h3 class="section-label">📤 Wgraj nowy skan mapy</h3>
    <form id="uploadMapForm" class="admin-form" enctype="multipart/form-data">
      <input type="hidden" name="noteSlug" value={slug} />

      <div class="file-drop" id="fileDrop">
        <input type="file" id="mapFile" name="file" accept="image/png,image/jpeg,image/svg+xml,image/webp" required />
        <div class="drop-hint">
          <span class="drop-icon">🖼️</span>
          <span>Kliknij lub przeciągnij obraz (PNG, JPG, SVG, WEBP)</span>
          <span id="fileName" class="file-name"></span>
        </div>
      </div>

      <div id="uploadMsg" class="form-msg hidden"></div>

      <div class="form-actions">
        <button type="submit" class="btn-primary">Wgraj i przypisz do notatki</button>
      </div>
    </form>
  </div>

  <!-- Edytor Mermaid -->
  <div class="admin-section mermaid-section">
    <h3 class="section-label">✒️ Mapa w kodzie (Mermaid)</h3>
    <p class="hint">Wklej lub napisz diagram Mermaid. Zostanie zapisany jako treść notatki.</p>
    <div class="mermaid-editor">
      <textarea id="mermaidCode" class="mermaid-textarea" placeholder="graph TD;&#10;  A[Temat] --> B[Podtemat 1];&#10;  A --> C[Podtemat 2];"></textarea>
      <div class="mermaid-preview">
        <div id="mermaidPreview" class="mermaid-render">
          <p class="preview-hint">Podgląd pojawi się po wpisaniu kodu</p>
        </div>
      </div>
    </div>
    <div id="mermaidMsg" class="form-msg hidden"></div>
    <div class="form-actions">
      <button id="saveMermaid" class="btn-primary">Zapisz diagram w notatce</button>
    </div>
  </div>

</BaseLayout>

<script type="module">
  import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs';
  mermaid.initialize({ startOnLoad: false, theme: 'dark' });

  function apiNotatkiUrl(s) {
    return '/api/notatki/' + s.split('/').map(encodeURIComponent).join('/');
  }

  const fileInput = document.getElementById('mapFile');
  const fileName = document.getElementById('fileName');
  fileInput.addEventListener('change', () => {
    fileName.textContent = fileInput.files[0]?.name || '';
  });

  // Upload skanu
  document.getElementById('uploadMapForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const msg = document.getElementById('uploadMsg');
    msg.className = 'form-msg';
    msg.textContent = 'Wgrywanie...';
    const res = await fetch('/api/upload-map', { method: 'POST', body: formData });
    const json = await res.json();
    if (res.ok) {
      msg.className = 'form-msg success';
      msg.textContent = `✓ Mapa "${json.filename}" wgrana i przypisana do notatki!`;
      setTimeout(() => location.reload(), 1200);
    } else {
      msg.className = 'form-msg error';
      msg.textContent = `Błąd: ${json.error}`;
    }
  });

  // Podgląd Mermaid na żywo
  const textarea = document.getElementById('mermaidCode');
  const preview = document.getElementById('mermaidPreview');
  let renderTimeout;

  textarea.addEventListener('input', () => {
    clearTimeout(renderTimeout);
    renderTimeout = setTimeout(async () => {
      const code = textarea.value.trim();
      if (!code) return;
      try {
        const id = 'mermaid-' + Date.now();
        const { svg } = await mermaid.render(id, code);
        preview.innerHTML = svg;
      } catch {
        preview.innerHTML = '<p class="preview-hint preview-error">Błąd w składni diagramu</p>';
      }
    }, 500);
  });

  // Zapis Mermaid do notatki (jako blok kodu w treści)
  document.getElementById('saveMermaid').addEventListener('click', async () => {
    const code = textarea.value.trim();
    if (!code) return alert('Wpisz kod Mermaid');
    const slug = document.querySelector('input[name="noteSlug"]').value;
    const msg = document.getElementById('mermaidMsg');
    msg.className = 'form-msg';
    msg.textContent = 'Zapisywanie...';

    const res = await fetch(apiNotatkiUrl(slug), {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mermaidCode: code, type: 'mapa' }),
    });
    const json = await res.json();
    if (res.ok) {
      msg.className = 'form-msg success';
      msg.textContent = '✓ Diagram zapisany w notatce!';
    } else {
      msg.className = 'form-msg error';
      msg.textContent = `Błąd: ${json.error}`;
    }
  });
</script>

<style>
  .admin-nav {
    width: 100%;
    max-width: 760px;
    display: flex;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  .btn-small {
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
    text-decoration: none;
    display: inline-flex;
  }
  .admin-section {
    width: 100%;
    max-width: 760px;
    margin-bottom: 3rem;
  }
  .section-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .current-map {
    width: 100%;
    max-width: 760px;
    margin-bottom: 2.5rem;
  }
  .map-preview { text-align: center; }
  .map-img {
    max-width: 100%;
    max-height: 400px;
    border-radius: 8px;
    border: 1px solid var(--border);
  }
  .map-filename {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-dim);
    margin-top: 0.5rem;
  }
  .no-map {
    width: 100%;
    max-width: 760px;
    padding: 1rem;
    color: var(--text-dim);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }
  .admin-form { max-width: 560px; }
  .file-drop {
    position: relative;
    background: var(--surface);
    border: 2px dashed var(--border);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s;
    margin-bottom: 1rem;
  }
  .file-drop:hover { border-color: var(--accent); }
  .file-drop input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }
  .drop-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    pointer-events: none;
    color: var(--text-dim);
  }
  .drop-icon { font-size: 2rem; }
  .file-name { color: var(--accent); font-size: 0.9rem; }
  .hint { font-size: 0.8rem; color: var(--text-dim); margin-bottom: 1rem; }

  .mermaid-editor {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .mermaid-textarea {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    padding: 1rem;
    border-radius: 10px;
    resize: vertical;
    min-height: 250px;
    outline: none;
  }
  .mermaid-textarea:focus { border-color: var(--accent); }
  .mermaid-render {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem;
    min-height: 250px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: auto;
  }
  .preview-hint { color: var(--text-dim); font-size: 0.8rem; text-align: center; }
  .preview-error { color: var(--red); }

  .form-actions { margin-top: 0.5rem; }
  .btn-primary {
    padding: 0.75rem 1.5rem;
    border-radius: 10px;
    border: 1px solid var(--accent);
    background: rgba(124,106,247,0.12);
    color: var(--accent);
    font-family: 'Syne', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-primary:hover { background: rgba(124,106,247,0.25); }
  .form-msg { padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.9rem; margin-top: 0.75rem; }
  .form-msg.hidden { display: none; }
  .form-msg.success { background: rgba(74,247,154,0.1); color: var(--green); border: 1px solid var(--green); }
  .form-msg.error { background: rgba(247,74,106,0.1); color: var(--red); border: 1px solid var(--red); }

  @media (max-width: 600px) {
    .mermaid-editor { grid-template-columns: 1fr; }
  }
</style>
